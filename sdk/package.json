{
  "name": "@veritoken/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Veritoken smart contracts on Stellar Soroban",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=12.0.0"
  },
  "devDependencies": {
    "@stellar/stellar-sdk": "^12.3.0",
    "typescript": "^5.4.5"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "stellar",
    "soroban",
    "rwa",
    "veritoken",
    "kyc",
    "compliance"
  ],
  "license": "MIT"
}
